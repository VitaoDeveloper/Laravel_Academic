APP_NAME=laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=pt_BR

# ---- Database ----
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=
DB_USERNAME=postgres
DB_PASSWORD=
DB_SSLMODE=require

# ---- Cache  ----
CACHE_STORE=database
QUEUE_CONNECTION=database

# ---- Logs ----
LOG_CHANNEL=stack
LOG_LEVEL=debug

# ---- Mail (dev) ----
MAIL_MAILER=log